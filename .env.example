# -----------------------------------------------------------------------
# VIPET — Environment variable reference
# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed to source control.
# -----------------------------------------------------------------------

# ── Django core ─────────────────────────────────────────────────────────
# Generate a secure key with:  python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Set to "True" only in development; always "False" in production
DEBUG=False

# Comma-separated list of hostnames/IPs Django is allowed to serve
# Example: ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (MySQL 8+) ──────────────────────────────────────────────────
DB_NAME=vipet_db
DB_USER=vipet_user
DB_PASSWORD=your-db-password
DB_HOST=127.0.0.1
DB_PORT=3306

# ── Database (PostgreSQL — for Railway/Render deployment) ────────────────
# If DATABASE_URL is set, it takes priority over DB_* variables above.
# Railway/Render automatically provide this variable.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Email (SMTP) ─────────────────────────────────────────────────────────
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@yourdomain.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=VIPET <noreply@yourdomain.com>

# ── Cloudinary (optional — leave blank to use local filesystem storage) ──
# If all three values are set, media files are uploaded to Cloudinary.
# If any value is empty, local MEDIA_ROOT storage is used instead.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Stripe Payment Gateway ────────────────────────────────────────────────
# Server-side secret key (sk_test_... or sk_live_...)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# Webhook signing secret (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
